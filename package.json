{
  "name": "landit",
  "version": "1.0.0",
  "private": true,
  "description": "LandIt - Job Placement Platform",
  "scripts": {
    "dev:frontend": "cd frontend && npm run serve",
    "build:frontend": "cd frontend && npm run build",
