{
  "name": "landit-backend",
  "version": "1.0.0",
  "description": "LandIt backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "jest": {
  "preset": "ts-jest",
  "testEnvironment": "node",
  "testMatch": ["**/src/services/__tests__/**/*.test.ts"]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.3",
    "compromise": "^14.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
